{
  "name": "foutraz/weather",
  "type": "library",
  "description": "OpenWeatherMap SDK for PHP / Laravel",
  "license": "MIT",
  "authors": [
    {
      "name": "Quentin MARI",
      "email": "quentin.mari0409@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "guzzlehttp/guzzle": "^7.0",
    "illuminate/support": "^11.0|^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "Foutraz\\Weather\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Foutraz\\Weather\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Foutraz\\Weather\\Providers\\WeatherServiceProvider"
      ]
    }
  }
}
